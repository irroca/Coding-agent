# DeepSeek (default)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional: Qwen (DashScope OpenAI-compatible mode)
# DASHSCOPE_API_KEY=sk-your-dashscope-key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=qwen3-coder-plus

# Optional: Moonshot Kimi
# MOONSHOT_API_KEY=sk-your-moonshot-key
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# MOONSHOT_MODEL=kimi-k2-0905-preview

# Optional: OpenAI / Anthropic (reserved)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Active provider: deepseek | qwen | moonshot | openai | anthropic
CODING_AGENT_PROVIDER=deepseek

# Logging level: DEBUG | INFO | WARNING | ERROR
CODING_AGENT_LOG_LEVEL=INFO
